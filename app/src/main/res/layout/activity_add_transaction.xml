<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="@color/onBackground"
            android:contentDescription="뒤로가기"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="거래 추가"
            android:textColor="@color/onBackground"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Area Scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/clToolbar"
        app:layout_constraintBottom_toTopOf="@id/btnSave">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- Type Segmented Button -->
            <RadioGroup
                android:id="@+id/rgType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_spinner"
                android:padding="4dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbExpense"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:button="@null"
                    android:background="@drawable/bg_segmented_left"
                    android:textColor="@color/bg_segmented_text_color"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:text="지출"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbIncome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:button="@null"
                    android:background="@drawable/bg_segmented_right"
                    android:textColor="@color/bg_segmented_text_color"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:text="수입" />
            </RadioGroup>

            <!-- Amount Input: Figma-style large centered amount -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₩"
                    android:textColor="@color/onBackground"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="4dp" />

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="100dp"
                    android:hint="0"
                    android:inputType="number"
                    android:textColor="@color/onBackground"
                    android:textColorHint="@color/text_muted"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:background="@color/primary" />

            <!-- Category Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="카테고리 선택"
                android:textColor="@color/onSurfaceVariant"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <!-- Row 1: 식비, 교통, 쇼핑 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardFood"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline"
                        app:cardBackgroundColor="@color/surface"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/cat_food_bg">
                                <ImageView
                                    android:id="@+id/ivFood"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_category_food"
                                    app:tint="@color/cat_food_icon"
                                    android:contentDescription="식비" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tvFood"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="식비"
                                android:textColor="@color/onSurface"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTransport"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline"
                        app:cardBackgroundColor="@color/surface"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/cat_transport_bg">
                                <ImageView
                                    android:id="@+id/ivTransport"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_category_transport"
                                    app:tint="@color/cat_transport_icon"
                                    android:contentDescription="교통" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tvTransport"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="교통"
                                android:textColor="@color/onSurface"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardShopping"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline"
                        app:cardBackgroundColor="@color/surface"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/cat_shopping_bg">
                                <ImageView
                                    android:id="@+id/ivShopping"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_category_shopping"
                                    app:tint="@color/cat_shopping_icon"
                                    android:contentDescription="쇼핑" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tvShopping"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="쇼핑"
                                android:textColor="@color/onSurface"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 2: 생활비, 문화, 기타 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardLiving"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline"
                        app:cardBackgroundColor="@color/surface"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/cat_living_bg">
                                <ImageView
                                    android:id="@+id/ivLiving"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_category_living"
                                    app:tint="@color/cat_living_icon"
                                    android:contentDescription="생활비" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tvLiving"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="생활비"
                                android:textColor="@color/onSurface"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCulture"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline"
                        app:cardBackgroundColor="@color/surface"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/cat_culture_bg">
                                <ImageView
                                    android:id="@+id/ivCulture"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_category_culture"
                                    app:tint="@color/cat_culture_icon"
                                    android:contentDescription="문화" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tvCulture"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="문화"
                                android:textColor="@color/onSurface"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOther"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="1dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline"
                        app:cardBackgroundColor="@color/surface"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="14dp"
                            android:gravity="center">
                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/cat_other_bg">
                                <ImageView
                                    android:id="@+id/ivOther"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_category_other"
                                    app:tint="@color/cat_other_icon"
                                    android:contentDescription="기타" />
                            </FrameLayout>
                            <TextView
                                android:id="@+id/tvOther"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="기타"
                                android:textColor="@color/onSurface"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <!-- Date Picker Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="날짜 선택"
                android:textColor="@color/onSurfaceVariant"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outline"
                app:cardBackgroundColor="@color/surface"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/primary"
                        android:contentDescription="날짜 선택" />

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="2026-06-23"
                        android:textColor="@color/onSurface"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_back"
                        android:rotation="180"
                        app:tint="@color/onSurfaceVariant"
                        android:contentDescription="날짜 이동" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Memo Input Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="메모"
                android:textColor="@color/onSurfaceVariant"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outline"
                app:cardBackgroundColor="@color/surface">

                <EditText
                    android:id="@+id/etMemo"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:paddingHorizontal="16dp"
                    android:hint="메모 입력 (선택 사항)"
                    android:textColor="@color/onSurface"
                    android:textColorHint="@color/text_muted"
                    android:textSize="15sp"
                    android:background="@android:color/transparent"
                    android:inputType="text"
                    android:gravity="center_vertical"
                    android:imeOptions="actionDone"
                    android:importantForAutofill="no" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Save Button: 64dp height, full width, 20dp radius -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:text="저장하기"
        android:textColor="@color/onPrimary"
        android:textSize="17sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary"
        app:cornerRadius="20dp"
        app:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>