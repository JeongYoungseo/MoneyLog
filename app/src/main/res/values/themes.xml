<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MoneyLog" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorPrimaryContainer">@color/primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/onPrimaryContainer</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        
        <!-- Background and Surface Colors -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/onSurface</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/onSurfaceVariant</item>
        <item name="colorOutline">@color/outline</item>

        <!-- Disable Material3 elevation overlay tint on surfaces (prevents green tint on cards) -->
        <item name="elevationOverlayEnabled">false</item>

        <!-- Typography configuration to use system sans-serif (Noto Sans KR equivalent) -->
        <item name="fontFamily">sans-serif</item>

        <!-- Other custom styles -->
        <item name="colorAccent">@color/primary</item>
        <item name="colorControlActivated">@color/primary</item>
    </style>

    <style name="Theme.MoneyLog" parent="Base.Theme.MoneyLog" />
</resources>